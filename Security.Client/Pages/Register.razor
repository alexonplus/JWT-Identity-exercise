@page "/register"
@using Security.Shared.DTOs
@inject HttpClient Http

<PageTitle>Registration</PageTitle>

<h3>User Registration</h3>

<div class="card p-3 shadow-sm" style="max-width: 400px;">
    <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input @bind="email" class="form-control" placeholder="example@mail.com" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <input @bind="password" type="password" class="form-control" />
    </div>
    <button class="btn btn-primary w-100" @onclick="HandleRegister">Create Account</button>

    @if (!string.IsNullOrEmpty(msg))
    {
        <div class="alert @(msg.StartsWith("Success") ? "alert-success" : "alert-danger") mt-3">
            @msg
        </div>
    }
</div>

@code {
    private string email = "";
    private string password = "";
    private string msg = "";

    private async Task HandleRegister()
    {
        msg = "Sending request...";
        
        // Using your DTO from the backend
        var model = new RegisterDto(email, password); 
        
        try 
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", model);

            if (response.IsSuccessStatusCode)
            {
                msg = "Success! User has been created.";
                email = ""; 
                password = "";
            }
            else
            {
                msg = "Error: Registration failed. Check API logs.";
            }
        }
        catch (Exception ex)
        {
            msg = $"Connection error: {ex.Message}";
        }
    }
}